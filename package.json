{
  "name": "ant-design-pro",
  "version": "5.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "dev": "npm run start:dev",
    "push-rsync": "rsync -avzhe ssh --delete-before dist/ ubuntu@203.162.10.113:/var/www/slink.ptit.edu.vn/",
    "push-rsync-win": "rsync -avzh --chmod=755 --no-perms --delete-before dist/ ubuntu@203.162.10.113:/var/www/slink.ptit.edu.vn/",
    "deploy": "npm run build && npm run push-rsync",
    "deploy-win": "npm run build && npm run push-rsync-win",
    "gh-pages": "gh-pages -d dist",
    "i18n-remove": "pro i18n-remove --locale=zh-CN --write",
    "lint": "npm run lint:js && npm run lint:style && npm run lint:prettier",
    "lint-staged": "lint-staged",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx ",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src && npm run lint:style",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier -c --write \"src/**/*\" --end-of-line auto",
    "lint:style": "stylelint --fix \"src/**/*.less\" --syntax less",
    "openapi": "max openapi",
    "precommit": "lint-staged",
    "prettier": "prettier -c --write \"src/**/*\"",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:dev": "cross-env REACT_APP_ENV=dev MOCK=none UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none UMI_ENV=dev max dev",
    "start:no-ui": "cross-env UMI_UI=none UMI_ENV=dev max dev",
    "start:pre": "cross-env REACT_APP_ENV=pre UMI_ENV=dev max dev",
    "start:test": "cross-env REACT_APP_ENV=test MOCK=none UMI_ENV=dev max dev",
    "pretest": "node ./tests/beforeTest",
    "test": "max test",
    "test:all": "node ./tests/run-tests.js",
    "test:component": "max test ./src/components",
    "tsc": "tsc --noEmit",
    "prepare": "husky install",
    "sentry:sourcemaps": ""
  },
  "lint-staged": {
    "**/*.less": "stylelint --syntax less",
    "**/*.{js,jsx,ts,tsx}": "npm run lint-staged:js",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "dependencies": {
    "@ant-design/icons": "^5.0.0",
    "@ant-design/pro-components": "^2.6.0",
    "@monaco-editor/react": "^4.6.0",
    "@sentry/react": "^7.65.0",
    "@tinymce/tinymce-react": "^4.2.0",
    "@umijs/max": "^4.0.0",
    "@umijs/route-utils": "^4.0.1",
    "antd": "^5.0.0",
    "antd-img-crop": "^4.2.4",
    "apexcharts": "^3.41.1",
    "axios": "^1.6.0",
    "classnames": "^2.3.0",
    "fs-extra": "^11.2.0",
    "js-file-download": "^0.4.12",
    "jsqr": "^1.4.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "path": "^0.12.7",
    "query-string": "^8.1.0",
    "react": "^18.2.0",
    "react-apexcharts": "^1.4.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-big-calendar": "^1.8.0",
    "react-countup": "^6.4.2",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^1.3.0",
    "react-highlight-words": "^0.20.0",
    "react-image-file-resizer": "^0.4.8",
    "react-infinite-scroll-component": "^6.1.0",
    "react-onesignal": "^3.0.0",
    "react-pdf": "^7.1.0",
    "react-responsive": "^9.0.2",
    "react-router-dom": "^6.14.0",
    "react-to-print": "^2.14.12",
    "socket.io-client": "^4.7.0",
    "styled-components": "^6.0.0",
    "tinymce": "^6.6.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@types/express": "^4.17.17",
    "@types/history": "^4.7.11",
    "@types/lodash": "^4.14.195",
    "@types/react": "^18.2.0",
    "@types/react-beautiful-dnd": "^13.1.4",
    "@types/react-big-calendar": "^1.6.4",
    "@types/react-dom": "^18.2.0",
    "@types/react-helmet": "^6.1.6",
    "@types/react-pdf": "^7.0.0",
    "@umijs/fabric": "^4.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "express": "^4.18.2",
    "gh-pages": "^5.0.0",
    "husky": "^8.0.3",
    "prettier": "^2.8.8",
    "stylelint": "^15.10.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "gitHooks": {
    "commit-msg": "fabric verify-commit"
  }
}
