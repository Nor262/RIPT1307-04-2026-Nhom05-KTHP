<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  
  <!-- SEO Primary Meta Tags -->
  <title>Equipment Management System - <%= context.config.define.APP_CONFIG_TEN_TRUONG.toUpperCase() %></title>
  <meta name="description" content="Hệ thống Quản lý Thiết bị dùng chung tại <%= context.config.define.APP_CONFIG_TEN_TRUONG %>. Giải pháp số hóa toàn diện vòng đời thiết bị: quản lý mượn/trả, in/quét mã QR, kiểm kê, bảo trì và thanh lý." />
  <meta name="keywords" content="<%= context.config.define.APP_CONFIG_TIEN_TO_TRUONG %>, <%= context.config.define.APP_CONFIG_TEN_TRUONG_VIET_TAT_TIENG_ANH %>, quản lý thiết bị, equipment management system, mượn trả thiết bị, quét mã QR, quản lý tài sản, chuyển đổi số" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="<%= context.config.define.APP_CONFIG_TEN_TRUONG_VIET_TAT_TIENG_ANH %> Group" />
  <link rel="canonical" href="https://equipmentmanagementsystem.netlify.app/" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://equipmentmanagementsystem.netlify.app/" />
  <meta property="og:title" content="Equipment Management System - <%= context.config.define.APP_CONFIG_TEN_TRUONG %>" />
  <meta property="og:description" content="Giải pháp toàn diện quản lý vòng đời thiết bị, mượn/trả nhanh chóng bằng QR code tại <%= context.config.define.APP_CONFIG_TEN_TRUONG %>." />
  <meta property="og:image" content="https://equipmentmanagementsystem.netlify.app/metadata.png" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://equipmentmanagementsystem.netlify.app/" />
  <meta property="twitter:title" content="Equipment Management System - <%= context.config.define.APP_CONFIG_TEN_TRUONG %>" />
  <meta property="twitter:description" content="Giải pháp toàn diện quản lý vòng đời thiết bị, mượn/trả nhanh chóng bằng QR code tại <%= context.config.define.APP_CONFIG_TEN_TRUONG %>." />
  <meta property="twitter:image" content="https://equipmentmanagementsystem.netlify.app/metadata.png" />

  <!-- Google Font preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/png" href="<%= context.config.publicPath %>favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/png" href="<%= context.config.publicPath %>favicon.png" sizes="32x32" />
  <link rel="shortcut icon" href="<%= context.config.publicPath %>favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="<%= context.config.publicPath %>apple-touch-icon.png" />
  <link rel="manifest" href="<%= context.config.publicPath %>site.webmanifest" />
  <style>
    :root {
      /* Hỗ trợ đổi màu realtime */
      --primary-color: var(--ant-primary-color);
      /* Background selected */
      --primary-1: var(--ant-primary-1)
    }
  </style>
  <!-- Schema.org Structured Data (JSON-LD) for WebApplication and WebSite -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "@id": "https://equipmentmanagementsystem.netlify.app/#webapp",
        "url": "https://equipmentmanagementsystem.netlify.app/",
        "name": "Equipment Management System",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "All",
        "browserRequirements": "Requires HTML5. Requires JavaScript.",
        "description": "Hệ thống Quản lý Thiết bị dùng chung tại <%= context.config.define.APP_CONFIG_TEN_TRUONG %>. Giải pháp số hóa toàn diện vòng đời thiết bị: quản lý mượn/trả, in/quét mã QR, kiểm kê, bảo trì và thanh lý.",
        "provider": {
          "@type": "Organization",
          "name": "<%= context.config.define.APP_CONFIG_TEN_TRUONG %>",
          "url": "https://equipmentmanagementsystem.netlify.app/"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://equipmentmanagementsystem.netlify.app/#website",
        "url": "https://equipmentmanagementsystem.netlify.app/",
        "name": "Equipment Management System",
        "description": "Cổng thông tin quản lý thiết bị đa nền tảng.",
        "publisher": {
          "@type": "Organization",
          "name": "<%= context.config.define.APP_CONFIG_TEN_TRUONG %>"
        }
      }
    ]
  }
  </script>
</head>

<body>

  <noscript>Xin lỗi, chúng tôi cần trình duyệt của bạn chạy Javascript</noscript>
  <div id="root"></div>

</body>

</html>